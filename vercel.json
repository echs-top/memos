    { "source": "/file/:match*", "destination": "https://memos.echs.top/file/:match*" },
    { "source": "/o/:match*", "destination": "https://memos.echs.top/o/:match*" },
    { "source": "/u/:match*", "destination": "https://memos.echs.top/u/:match*" },
