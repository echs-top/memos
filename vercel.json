{
  "version": 2,
  "rewrites": [
    { "source": "/(?<route>api/.*)", "destination": "https://memos.echs.top/:route" },
    { "source": "/(?<route>memos.api.v1..*)", "destination": "https://memos.echs.top/:route" },
    { "source": "/(?<route>file/.*)", "destination": "https://memos.echs.top/:route" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
